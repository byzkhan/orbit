{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "outDir": "./out/cli",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["src/shared/*"]
    },
    "skipLibCheck": true
  },
  "include": [
    "src/cli/**/*",
    "src/core/**/*",
    "src/main/agent/**/*",
    "src/main/auth/**/*",
    "src/main/db/**/*",
    "src/main/tools/**/*",
    "src/shared/**/*"
  ],
  "exclude": [
    "src/main/index.ts",
    "src/main/window.ts",
    "src/main/ipc/**/*"
  ]
}
